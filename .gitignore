.DS_Store
Thumbs.db

# --- Data: synthetic datasets and DB dumps stay out of git ---
# Rationale: AMLSim output can be large and is regenerable from seed config;
# committing it bloats repo history for no reproducibility gain.
data/
*.csv
*.sql.gz
*.dump

# --- ChromaDB local persistence (step 5) ---
chroma_db/
*.sqlite3

# --- Logs ---
*.log

# --- Streamlit ---
.streamlit/secrets.toml