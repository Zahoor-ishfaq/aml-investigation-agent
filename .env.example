# Copy to .env and fill in. Never commit .env — only .env.example.

# --- Postgres ---
POSTGRES_USER=aml_app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aml_investigation
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full DSN, used directly by SQLAlchemy engine — kept as one var so
# config.py doesn't need to reassemble it from parts in more than one place.
DATABASE_URL=postgresql+psycopg2://aml_app:changeme@localhost:5432/aml_investigation
